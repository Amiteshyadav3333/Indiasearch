# Elasticsearch Cloud Configuration
ELASTIC_URL=https://your-deployment.es.cloud:443
ELASTIC_USERNAME=elastic
ELASTIC_PASSWORD=your_password_here

# Optional: OpenAI (for better AI summaries)
OPENAI_API_KEY=sk-your-key-here
BING_API_KEY=your_bing_api_key_here
BING_DAILY_LIMIT=100

# Last-resort paid fallback. Called only when free sources/Bing return weak results.
SERPER_API_KEY=your_serper_api_key_here
SERPER_DAILY_LIMIT=80
